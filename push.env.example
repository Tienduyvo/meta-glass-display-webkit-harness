# Copy this file to `push.env` (git-ignored) and fill in your real values.
# tools/push.py and tools/qr.py read these; NEVER commit real credentials.
GLASS_API=https://<your-worker>.workers.dev/api
GLASS_TOKEN=<your app password / API_SECRET>
GLASS_LAUNCHER=https://<your-worker>.workers.dev/#glass&t=<your app password>
# Your D1 database id (from `npx wrangler d1 list`). tools/deploy.py fills this in
# automatically and injects it into wrangler.toml only while deploying — the tracked
# toml always keeps its placeholder.
D1_DATABASE_ID=<your D1 database id>
