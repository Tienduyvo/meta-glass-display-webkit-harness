diff --git a/src/claude/relay-backend.ts b/src/claude/relay-backend.ts
new file mode 100644
index 0000000..ffa06b8
--- /dev/null
+++ b/src/claude/relay-backend.ts
@@ -0,0 +1,159 @@
+import {
+    appendFileSync,
+    existsSync,
+    mkdirSync,
+    readFileSync,
+    readdirSync,
+    statSync,
+    unlinkSync
+} from 'fs'
+import { join } from 'path'
+import { randomUUID } from 'crypto'
+import {
+    ClaudeBackend,
+    type ClaudeResponse,
+    type PermissionCallback,
+    type SessionCallback
+} from './backend.ts'
+import type { Config, PermissionMode } from '../types.ts'
+import type { Logger } from '../utils/logger.ts'
+
+// The listener (an interactive Claude Code session watching inbox.jsonl) touches
+// listener.alive every few seconds. Older than this = listener gone, fall back
+// to the headless SDK backend so the bridge never goes dark.
+const HEARTBEAT_MAX_AGE_MS = 60_000
+const REPLY_TIMEOUT_MS = 10 * 60_000
+const POLL_INTERVAL_MS = 500
+
+/**
+ * Relay backend: hands incoming messages to a LIVE interactive Claude Code
+ * session on this machine instead of spawning a headless SDK session.
+ * Interactive sessions have capabilities headless ones can't get (the Claude
+ * in Chrome extension connects via native messaging to interactive sessions
+ * only), so relaying gives WhatsApp the full desktop toolset.
+ *
+ * Protocol (all files under the relay dir, e.g. ~/.whatsapp-claude-agent/relay):
+ *   inbox.jsonl        daemon appends {id, ts, text} per incoming message
+ *   outbox/<id>.txt    listener writes the reply (atomically: .tmp then rename)
+ *   listener.alive     listener touches this as a heartbeat
+ *
+ * Enabled via the WA_RELAY_DIR environment variable. Falls back to the wrapped
+ * SDK backend when no listener heartbeat is fresh; fallback replies are
+ * prefixed with [headless] so the user knows the desktop session was offline.
+ */
+export class RelayBackend extends ClaudeBackend {
+    private inner: ClaudeBackend
+    private inboxPath: string
+    private outboxDir: string
+    private heartbeatPath: string
+
+    constructor(config: Config, logger: Logger, inner: ClaudeBackend, relayDir: string) {
+        super(config, logger)
+        this.inner = inner
+        this.inboxPath = join(relayDir, 'inbox.jsonl')
+        this.outboxDir = join(relayDir, 'outbox')
+        this.heartbeatPath = join(relayDir, 'listener.alive')
+
+        mkdirSync(this.outboxDir, { recursive: true })
+        // Orphaned replies from a previous run would be misdelivered to new ids
+        // never — ids are unique — but they'd accumulate forever; clear them.
+        for (const f of readdirSync(this.outboxDir)) {
+            try {
+                unlinkSync(join(this.outboxDir, f))
+            } catch {
+                // best effort
+            }
+        }
+        this.logger.info(`Relay mode enabled: ${relayDir} (fallback: headless SDK)`)
+    }
+
+    private listenerAlive(): boolean {
+        try {
+            const age = Date.now() - statSync(this.heartbeatPath).mtimeMs
+            return age < HEARTBEAT_MAX_AGE_MS
+        } catch {
+            return false
+        }
+    }
+
+    private async fallback(
+        prompt: string,
+        conversationHistory: string[] | undefined,
+        reason: string
+    ): Promise<ClaudeResponse> {
+        this.logger.warn(`Relay fallback to headless SDK backend: ${reason}`)
+        const res = await this.inner.query(prompt, conversationHistory)
+        if (res.error) return res
+        return { ...res, text: `[headless] ${res.text}` }
+    }
+
+    async query(prompt: string, conversationHistory?: string[]): Promise<ClaudeResponse> {
+        if (!this.listenerAlive()) {
+            return this.fallback(prompt, conversationHistory, 'no listener heartbeat')
+        }
+
+        const id = randomUUID()
+        const record = { id, ts: new Date().toISOString(), text: prompt }
+        appendFileSync(this.inboxPath, JSON.stringify(record) + '\n')
+        this.logger.info(`Relayed message ${id} to listener, waiting for reply...`)
+
+        const replyPath = join(this.outboxDir, `${id}.txt`)
+        const deadline = Date.now() + REPLY_TIMEOUT_MS
+        while (Date.now() < deadline) {
+            if (existsSync(replyPath)) {
+                const text = readFileSync(replyPath, 'utf-8').trim()
+                try {
+                    unlinkSync(replyPath)
+                } catch {
+                    // best effort
+                }
+                this.logger.info(`Relay reply for ${id}: ${text.length} chars`)
+                return { text: text || 'No response generated.' }
+            }
+            if (!this.listenerAlive()) {
+                return this.fallback(prompt, conversationHistory, 'listener died mid-wait')
+            }
+            await new Promise((r) => setTimeout(r, POLL_INTERVAL_MS))
+        }
+        return this.fallback(prompt, conversationHistory, `no reply within ${REPLY_TIMEOUT_MS}ms`)
+    }
+
+    async stop(): Promise<void> {
+        await this.inner.stop()
+    }
+
+    // The fallback path must behave exactly like a plain SDK run, so every
+    // mutable knob is forwarded to the wrapped backend. Config-object setters
+    // in the base class already share state (same config reference).
+
+    override setMode(mode: PermissionMode): void {
+        super.setMode(mode)
+        this.inner.setMode(mode)
+    }
+
+    override setPermissionCallback(callback: PermissionCallback): void {
+        super.setPermissionCallback(callback)
+        this.inner.setPermissionCallback(callback)
+    }
+
+    override setSessionCallback(callback: SessionCallback): void {
+        super.setSessionCallback(callback)
+        this.inner.setSessionCallback(callback)
+    }
+
+    override getSessionId(): string | undefined {
+        return this.inner.getSessionId()
+    }
+
+    override setSessionId(sessionId: string | undefined): void {
+        this.inner.setSessionId(sessionId)
+    }
+
+    override setForkSession(fork: boolean): void {
+        this.inner.setForkSession(fork)
+    }
+
+    override getForkSession(): boolean {
+        return this.inner.getForkSession()
+    }
+}
